datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum VideoPlatform {
  YOUTUBE
  INSTAGRAM
}

model Comparison {
  id                String       @id @default(uuid())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  // Input URLs
  inputUrls         String[]
  
  // Status of the entire comparison
  status            JobStatus    @default(PENDING)
  error             String?
  progress          Int          @default(0) // 0 to 100
  currentStep       String?      // e.g., "Downloading Audio", "Transcribing"
  
  // Relations
  videos            Video[]
  analysis          AnalysisReport?
  chats             ChatSession[]
}

model Video {
  id                String       @id @default(uuid())
  comparisonId      String
  comparison        Comparison   @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  
  platform          VideoPlatform
  externalId        String       // YouTube Video ID or Instagram shortcode
  url               String
  
  // Metadata
  title             String?
  creatorName       String?
  followerCount     Int?         // Instagram specific
  views             Int?
  likes             Int?
  comments          Int?
  uploadDate        DateTime?
  duration          Int?         // In seconds
  thumbnailUrl      String?
  extractionMethod  String       @default("Unknown")
  rawMetadata       Json?
  extractionLogs    Json?
  
  // Analytics
  engagementRate    Float?       // (likes + comments) / views * 100
  
  // Transcript details
  transcript        String?      // Full transcript text
  
  // Relations
  chunks            VideoChunk[]
  
  createdAt         DateTime     @default(now())
  
  @@unique([comparisonId, externalId])
}

model VideoChunk {
  id                String       @id @default(uuid())
  videoId           String
  video             Video        @relation(fields: [videoId], references: [id], onDelete: Cascade)
  
  chunkIndex        Int
  text              String
  startTime         Float        // In seconds
  endTime           Float        // In seconds
  // Note: embedding column is added natively now to prevent drops
  embedding         Unsupported("vector(384)")?
  
  createdAt         DateTime     @default(now())
}

model AnalysisReport {
  id                String       @id @default(uuid())
  comparisonId      String       @unique
  comparison        Comparison   @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  
  // Structured comparison insights generated by GPT-4o
  summary           String
  hookAnalysis      String
  pacingStructure   String
  ctaEffectiveness  String
  keyTakeaways      String
  rawGptOutput      Json
  
  createdAt         DateTime     @default(now())
}

model ChatSession {
  id                String       @id @default(uuid())
  comparisonId      String
  comparison        Comparison   @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  
  title             String       @default("Chat Session")
  createdAt         DateTime     @default(now())
  messages          ChatMessage[]
}

model ChatMessage {
  id                String       @id @default(uuid())
  chatSessionId     String
  chatSession       ChatSession  @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  
  role              String       // "user" or "assistant"
  content           String
  citations         Json?        // Array of source chunks, time offsets, and video platforms
  
  createdAt         DateTime     @default(now())
}

model CreatorCache {
  id              String        @id @default(uuid())
  platform        VideoPlatform
  username        String
  followerCount   Int
  retrievedAt     DateTime      @default(now())
  source          String
  confidence      Float         // e.g., 100.0 for verified
  
  @@unique([platform, username])
}
